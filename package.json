{
  "name": "gambti",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare": "panda codegen --silent",
    "dev": "panda codegen && vite",
    "build": "panda codegen && tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "panda codegen && tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "api:gen": "openapi-typescript docs/03-api/openapi.json -o src/types/api.ts"
  },
  "dependencies": {
    "@ark-ui/react": "^5.0.0",
    "@hookform/resolvers": "^5.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-query-devtools": "^5.0.0",
    "ky": "^1.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "react-router-dom": "^7.0.0",
    "zod": "^3.25.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@pandacss/dev": "^0.53.0",
    "@park-ui/panda-preset": "^0.43.1",
    "@playwright/test": "^1.50.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.0.0",
    "msw": "^2.0.0",
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
